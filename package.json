{
  "name": "mcp-kb-server",
  "version": "1.0.0",
  "description": "MCP Knowledge Base Server — paginated frontmatter search for Claude Code",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "start:sse": "TRANSPORT=sse node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "TRANSPORT=http tsx src/index.ts",
    "dev:sse": "TRANSPORT=sse tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}